# =============================================================================
# Telegram Bot (required)
# Obtain token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional: webhook mode (otherwise uses long polling)
# TELEGRAM_BOT_WEBHOOK_URL=https://your.domain/telegram_bot
# TELEGRAM_BOT_WEBHOOK_PORT=9487

# =============================================================================
# Database
# Primary: PostgreSQL (recommended for production)
# DATABASE_URL=postgres://user:password@host:5432/dbname
# Alternative env name supported by config (Go legacy)
# DB_CONNECTION_STR=postgresql://user:password@host:5432/dbname

# Fallback: SQLite file (used when Postgres is absent or unreachable)
# Leave empty or unset to use default: data/dev.db
# SQLITE_PATH=data/dev.db

# =============================================================================
# OpenAI (required)
OPENAI_API_KEY=sk-xxxx
# Optional relay / proxy host, e.g. https://openai.example.com
# OPENAI_API_HOST=
# Model name; defaults to gpt-5.1 if unset
OPENAI_API_MODEL_NAME=gpt-5.1
# Maximum output tokens (max_tokens parameter)
OPENAI_API_TOKEN_LIMIT=128000
# Context window limit for chat history recap input
OPENAI_API_CHAT_HISTORIES_RECAP_TOKEN_LIMIT=400000

# =============================================================================
# Sarcastic Condensed Summary (optional customization)
# Separate model for condensed summary; falls back to OPENAI_API_MODEL_NAME if unset
SARCASTIC_CONDENSED_MODEL_NAME=gpt-5.1
# Custom system prompt for condensed summary (leave blank to use built-in default)
SARCASTIC_CONDENSED_SYSTEM_PROMPT=
# Custom user prompt template (use {{chat_history}} as placeholder; leave blank for default)
SARCASTIC_CONDENSED_USER_PROMPT=
# Language for chat history summarization (default: Simplified Chinese)
CHAT_HISTORIES_SUMMARIZATION_LANGUAGE=Simplified Chinese

# =============================================================================
# Check / Format Verification Model (optional)
# Repairs malformed condensed or segmented AI outputs
# CHECK_MODEL=gpt-5.4-xhigh
# CHECK_MODEL_backup=gpt-5.1

# =============================================================================
# Telegraph (optional, for long content publishing)
# Get token from https://telegra.ph/api
TELEGRAPH_ACCESS_TOKEN=
# Custom author name for Telegraph pages
TELEGRAPH_AUTHOR_NAME=Insights Bot
# Optional: custom API URL and timeout (seconds)
# TELEGRAPH_API_URL=https://api.telegra.ph
# TELEGRAPH_TIMEOUT_SEC=10

# =============================================================================
# Localization & Logging
# Default locale: en (options: en | zh-Hans | zh-Hant)
INSIGHTS_LANG=en
# Path to locales folder
# LOCALES_DIR=./locales
# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
# Log file path (optional, logs to stdout if unset)
# LOG_FILE_PATH=./logs/insights-bot.log
