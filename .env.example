# =============================================================================
# Telegram Bot (required)
# Obtain token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional: webhook mode (otherwise uses long polling)
# TELEGRAM_BOT_WEBHOOK_URL=https://your.domain/telegram_bot
# TELEGRAM_BOT_WEBHOOK_PORT=9487

# =============================================================================
# Database
# Primary: PostgreSQL (recommended for production)
# DATABASE_URL=postgres://user:password@host:5432/dbname
# Alternative env name supported by config (Go legacy)
# DB_CONNECTION_STR=

# Fallback: SQLite file (used when Postgres is absent or unreachable)
SQLITE_PATH=data/dev.db

# =============================================================================
# OpenAI
# Single OpenAI key is enough
# (the code still accepts OPENAI_API_SECRET for backward compatibility)
OPENAI_API_KEY=sk-xxxx
# OPENAI_API_SECRET=
# Optional relay / proxy host, e.g. https://openai.example.com
# OPENAI_API_HOST=
# Model name; defaults to gpt-5.1 if unset
OPENAI_API_MODEL_NAME=gpt-5.1
# Optional token limit hint for prompt shaping
OPENAI_API_TOKEN_LIMIT=400000

# =============================================================================
# Localization & logging
# Default locale: en (options: en | zh-Hans | zh-Hant)
INSIGHTS_LANG=en
# Path to locales folder
LOCALES_DIR=./locales
# Log level: trace|debug|info|warn|error
LOG_LEVEL=info
